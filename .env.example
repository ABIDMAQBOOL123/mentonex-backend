# ============================================================
# MENTONEX BACKEND CONFIGURATION
# ============================================================
# Copy this file to .env and fill in your values

# ============================================================
# SERVER
# ============================================================
PORT=8088
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ============================================================
# DATABASE (Optional - uses in-memory if not set)
# ============================================================
# MongoDB connection string
# DATABASE_URL=mongodb://localhost:27017/mentonex
# DATABASE_NAME=mentonex

# ============================================================
# AUTHENTICATION
# ============================================================
AUTH_ENABLED=false
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# ============================================================
# AI PROVIDERS
# ============================================================

# OpenAI - Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# Anthropic (Claude) - Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# ============================================================
# DISCORD INTEGRATION
# ============================================================
# 1. Go to https://discord.com/developers/applications
# 2. Create a new application
# 3. Go to "Bot" section and create a bot
# 4. Copy the token below
# 5. Enable "MESSAGE CONTENT INTENT" in Bot settings
# 6. Invite bot with: OAuth2 > URL Generator > bot + applications.commands
#    Permissions: Send Messages, Read Message History, Use Slash Commands

DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PREFIX=!

# ============================================================
# TELEGRAM INTEGRATION
# ============================================================
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow instructions
# 3. Copy the token below

TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ============================================================
# TWILIO INTEGRATION (Voice/SMS)
# ============================================================
# 1. Sign up at https://www.twilio.com/
# 2. Get credentials from Console Dashboard
# 3. Buy a phone number

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Webhook URLs (set these in Twilio Console):
# Voice: https://your-domain.com/api/twilio/voice
# SMS: https://your-domain.com/api/twilio/sms

# ============================================================
# SLACK INTEGRATION (Optional)
# ============================================================
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# ============================================================
# OPTIONAL SETTINGS
# ============================================================

# Logging
LOG_LEVEL=info

# Rate limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100

# File uploads
# MAX_FILE_SIZE=10485760
