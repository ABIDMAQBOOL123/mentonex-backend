{
  "watch": ["src"],
  "ext": "js,mjs,json",
  "ignore": [
    "node_modules/**/*",
    "logs/**/*",
    "*.log",
    "*.pid",
    "*.seed",
    "*.pid.lock",
    ".DS_Store",
    "Thumbs.db",
    ".env.local",
    ".env.development.local",
    ".env.test.local",
    ".env.production.local",
    "npm-debug.log*",
    "yarn-debug.log*",
    "yarn-error.log*",
    "package-lock.json",
    "yarn.lock",
    ".git/**/*",
    ".vscode/**/*",
    "coverage/**/*",
    "dist/**/*",
    "build/**/*",
    "tmp/**/*",
    "temp/**/*"
  ],
  "delay": 1000,
  "verbose": false
}